{
  "include": ["**/*"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "rootDirs": [],
    "composite": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "noEmit": true,
    "moduleResolution": "Bundler",
    "paths": {
      "*": ["./*"]
    }
  }
}
